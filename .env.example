# Supabase project settings — Project Settings > API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Web push VAPID public key, used by src/lib/usePushNotifications.ts.
# Generate a VAPID key pair (e.g. `npx web-push generate-vapid-keys`) and
# configure the matching private key + Supabase project URL/service role key
# as secrets on the send-push Edge Function (supabase/functions/send-push).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
